{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "lib": ["ES2020", "DOM"],
    "types": ["jest", "node"],
    "strict": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/**"]
    }
  }
}
