{

    "compilerOptions": {
      "lib": ["ES2020", "DOM"],
      "target": "ES2020",
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "outDir": "./dist/",
      "rootDir": "src",
      "strict": false,
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "skipLibCheck": true,
      "checkJs": false,
      "allowJs": false,
      "declaration": true,
      "declarationMap": false,
      "allowSyntheticDefaultImports": true,
      "types": ["jest", "node"]
    }
  }
